---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Services from '~/components/widgets/Services.astro';
import Reviews from '~/components/widgets/Reviews.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Steps from '~/components/widgets/Steps.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const metadata = {
  title: 'Dott.ssa Valentina di Gregorio | Dermatologa Venereologa a Pescara, Ortona, Porto San Giorgio, Civitanova Marche',
  ignoreTitleTemplate: true,
};

const miodottoreUrl = 'https://www.miodottore.it/valentina-di-gregorio/dermatologo-venereologo/monsampolo-del-tronto';
const linkedinUrl = 'https://www.linkedin.com/in/valentina-di-gregorio-046bb043/';
const siteUrl = 'https://www.dermatologavalentinadigregorio.it';
const physicianId = `${siteUrl}/#physician`;
const websiteId = `${siteUrl}/#website`;
const webpageId = `${siteUrl}/#webpage`;
const faqId = `${siteUrl}/#faq`;
const imageId = `${siteUrl}/#primaryimage`;
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": websiteId,
          "url": `${siteUrl}/`,
          "name": "Dott.ssa Valentina di Gregorio",
          "description": "Sito ufficiale della Dott.ssa Valentina di Gregorio, dermatologa, venereologa e tricologa.",
          "inLanguage": "it-IT",
          "publisher": { "@id": physicianId }
        },
        {
          "@type": "ImageObject",
          "@id": imageId,
          "url": `${siteUrl}/images/dottoressa.jpeg`,
          "contentUrl": `${siteUrl}/images/dottoressa.jpeg`,
          "caption": "Dott.ssa Valentina di Gregorio, dermatologa",
          "inLanguage": "it-IT"
        },
        {
          "@type": "WebPage",
          "@id": webpageId,
          "url": `${siteUrl}/`,
          "name": "Dott.ssa Valentina di Gregorio | Dermatologa Venereologa a Pescara, Ortona, Porto San Giorgio, Civitanova Marche",
          "isPartOf": { "@id": websiteId },
          "about": { "@id": physicianId },
          "primaryImageOfPage": { "@id": imageId },
          "inLanguage": "it-IT",
          "breadcrumb": { "@id": `${siteUrl}/#breadcrumb` }
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${siteUrl}/#breadcrumb`,
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` }
          ]
        },
        {
          "@type": "Physician",
          "@id": physicianId,
          "name": "Dott.ssa Valentina di Gregorio",
          "alternateName": "Valentina di Gregorio",
          "honorificPrefix": "Dott.ssa",
          "gender": "https://schema.org/Female",
          "jobTitle": "Dermatologa, Venereologa, Tricologa",
          "url": `${siteUrl}/`,
          "mainEntityOfPage": { "@id": webpageId },
          "image": { "@id": imageId },
          "description": "Dermatologa, venereologa e tricologa. Si occupa di dermatologia clinica, dermatologia oncologica, dermochirurgia, tricologia e diagnosi delle principali patologie della pelle, dei capelli e delle malattie sessualmente trasmissibili.",
          "medicalSpecialty": ["Dermatologic", "Venereology"],
          "knowsLanguage": ["it"],
          "knowsAbout": [
            "Dermatologia", "Venereologia", "Tricologia", "Dermatologia oncologica",
            "Dermochirurgia", "Mappatura nei", "Epiluminescenza", "Acne", "Rosacea",
            "Dermatite atopica", "Psoriasi", "Vitiligine", "Alopecia areata",
            "Alopecia androgenetica", "Infezioni cutanee", "Malattie sessualmente trasmissibili"
          ],
          "areaServed": [
            { "@type": "City", "name": "Pescara", "containedInPlace": { "@type": "AdministrativeArea", "name": "Abruzzo" } },
            { "@type": "City", "name": "Ortona", "containedInPlace": { "@type": "AdministrativeArea", "name": "Abruzzo" } },
            { "@type": "City", "name": "Sambuceto", "containedInPlace": { "@type": "AdministrativeArea", "name": "Abruzzo" } },
            { "@type": "City", "name": "Porto San Giorgio", "containedInPlace": { "@type": "AdministrativeArea", "name": "Marche" } },
            { "@type": "City", "name": "Civitanova Marche", "containedInPlace": { "@type": "AdministrativeArea", "name": "Marche" } },
            { "@type": "City", "name": "Monsampolo del Tronto", "containedInPlace": { "@type": "AdministrativeArea", "name": "Marche" } }
          ],
          "availableService": [
            { "@type": "MedicalProcedure", "name": "Prima visita dermatologica" },
            { "@type": "MedicalProcedure", "name": "Visita dermatologica" },
            { "@type": "MedicalProcedure", "name": "Visita dermatologica di controllo" },
            { "@type": "MedicalProcedure", "name": "Epiluminescenza" },
            { "@type": "MedicalProcedure", "name": "Mappatura nei" },
            { "@type": "MedicalProcedure", "name": "Prima visita tricologica" },
            { "@type": "MedicalProcedure", "name": "Visita tricologica" },
            { "@type": "MedicalProcedure", "name": "Trattamento verruche e molluschi" },
            { "@type": "MedicalProcedure", "name": "Visita dermatologica con epiluminescenza" },
            { "@type": "MedicalProcedure", "name": "Visita dermatologica con mappatura nei" }
          ],
          "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Università G. d'Annunzio di Chieti-Pescara" },
            { "@type": "CollegeOrUniversity", "name": "Università degli Studi di Siena" },
            { "@type": "CollegeOrUniversity", "name": "Università Vanvitelli di Napoli" }
          ],
          "hasCredential": [
            {
              "@type": "EducationalOccupationalCredential",
              "credentialCategory": "Laurea in Medicina e Chirurgia",
              "recognizedBy": { "@type": "CollegeOrUniversity", "name": "Università G. d'Annunzio di Chieti-Pescara" }
            },
            {
              "@type": "EducationalOccupationalCredential",
              "credentialCategory": "Specializzazione in Dermatologia e Venereologia",
              "recognizedBy": { "@type": "CollegeOrUniversity", "name": "Università G. d'Annunzio di Chieti-Pescara" }
            },
            {
              "@type": "EducationalOccupationalCredential",
              "credentialCategory": "Master di II livello in Dermochirurgia",
              "recognizedBy": { "@type": "CollegeOrUniversity", "name": "Università degli Studi di Siena" }
            },
            {
              "@type": "EducationalOccupationalCredential",
              "credentialCategory": "Master di II livello in Dermatologia Oncologica",
              "recognizedBy": { "@type": "CollegeOrUniversity", "name": "Università Vanvitelli di Napoli" }
            }
          ],
          "memberOf": [{ "@type": "Organization", "name": "S.I.Tri.", "description": "Società Italiana di Tricologia" }],
          "sameAs": [miodottoreUrl, linkedinUrl],
          "potentialAction": {
            "@type": "ReserveAction",
            "name": "Prenota una visita",
            "target": { "@type": "EntryPoint", "urlTemplate": miodottoreUrl, "actionPlatform": ["https://schema.org/DesktopWebPlatform", "https://schema.org/MobileWebPlatform"] },
            "result": { "@type": "Reservation", "name": "Visita dermatologica" }
          }
        },
        {
          "@type": "FAQPage",
          "@id": faqId,
          "isPartOf": { "@id": webpageId },
          "mainEntity": [
        {
          "@type": "Question",
          "name": "Dove visita la Dott.ssa Valentina di Gregorio a Ortona?",
          "acceptedAnswer": { "@type": "Answer", "text": "La Dott.ssa Valentina di Gregorio effettua visite dermatologiche anche a Ortona. Per conoscere disponibilità, giorni di visita e prenotare un appuntamento, è possibile utilizzare la pagina di prenotazione online." }
        },
        {
          "@type": "Question",
          "name": "Dove visita la Dott.ssa Valentina di Gregorio a Pescara?",
          "acceptedAnswer": { "@type": "Answer", "text": "La Dott.ssa Valentina di Gregorio riceve anche a Pescara per visite dermatologiche, tricologiche e controlli specialistici. Per verificare la sede disponibile e gli orari aggiornati, è possibile prenotare online." }
        },
        {
          "@type": "Question",
          "name": "La Dott.ssa Valentina di Gregorio visita anche a Civitanova Marche?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, la Dott.ssa Valentina di Gregorio visita anche a Civitanova Marche. La disponibilità può variare in base alla sede e al periodo, per questo è consigliabile consultare la prenotazione online per verificare giorni e orari disponibili." }
        },
        {
          "@type": "Question",
          "name": "La Dott.ssa Valentina di Gregorio visita anche a Porto San Giorgio?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, tra le località indicate per le visite dermatologiche della Dott.ssa Valentina di Gregorio è presente anche Porto San Giorgio. La prenotazione online consente di verificare la sede e la prima disponibilità utile." }
        },
        {
          "@type": "Question",
          "name": "È possibile prenotare una visita dermatologica online?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, è possibile prenotare online la visita dermatologica attraverso la pagina dedicata. In questo modo è possibile consultare le disponibilità e scegliere data e orario più comodi." }
        },
        {
          "@type": "Question",
          "name": "Quali servizi dermatologici offre?",
          "acceptedAnswer": { "@type": "Answer", "text": "Tra le principali prestazioni offerte ci sono prima visita dermatologica, visita di controllo, epiluminescenza, mappatura nei, visita tricologica, prima visita tricologica e trattamenti per verruche e molluschi." }
        },
        {
          "@type": "Question",
          "name": "Quando è consigliata una visita dermatologica?",
          "acceptedAnswer": { "@type": "Answer", "text": "Una visita dermatologica è consigliata in presenza di acne, rosacea, dermatite, psoriasi, infezioni cutanee, lesioni pigmentate, cambiamenti nei nei, prurito persistente, caduta dei capelli o altri disturbi della pelle e del cuoio capelluto." }
        },
        {
          "@type": "Question",
          "name": "Quando fare la mappatura dei nei?",
          "acceptedAnswer": { "@type": "Answer", "text": "La mappatura dei nei è utile per il controllo periodico delle lesioni pigmentate e per la prevenzione dei tumori cutanei. È particolarmente consigliata in caso di numerosi nei, familiarità per melanoma o cambiamenti recenti nell'aspetto di un neo." }
        },
        {
          "@type": "Question",
          "name": "La Dott.ssa Valentina di Gregorio si occupa anche di tricologia?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, la Dott.ssa Valentina di Gregorio si occupa anche di tricologia, con attenzione alla diagnosi e al trattamento di alopecia areata, alopecia androgenetica e patologie del cuoio capelluto." }
        },
        {
          "@type": "Question",
          "name": "La Dott.ssa Valentina di Gregorio si occupa di venereologia?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, la Dott.ssa Valentina di Gregorio si occupa anche di venereologia e della valutazione di alcune malattie sessualmente trasmissibili, verruche genitali e altre condizioni di interesse specialistico." }
        },
        {
          "@type": "Question",
          "name": "È possibile prenotare una visita per acne, dermatite o psoriasi?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì, è possibile prenotare una visita specialistica per acne, dermatite atopica, eczema, psoriasi, rosacea, vitiligine e altre patologie infiammatorie della pelle." }
        },
        {
          "@type": "Question",
          "name": "Come faccio a scegliere la sede più comoda?",
          "acceptedAnswer": { "@type": "Answer", "text": "Durante la prenotazione online è possibile verificare le disponibilità in base alla sede e scegliere quella più comoda tra le località indicate." }
        }
          ]
        }
      ]
    })} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Prenota una Visita',
        href: miodottoreUrl,
        target: '_blank',
        icon: 'tabler:calendar',
      },
      { text: 'Conosciamoci', href: '#chi-sono' },
    ]}
    image={{ src: '~/assets/images/dottoressa.jpeg', alt: 'Dottoressa Valentina di Gregorio dermatologa a Pescara e Ortona' }}
  >
    <Fragment slot="title"> Dott.ssa Valentina di Gregorio </Fragment>

    <Fragment slot="subtitle">
      <h2 class="font-semibold text-2xl md:text-3xl">Dermatologia, Venereologia e Tricologia</h2>
      <h2 class="text-sm md:text-base text-muted mt-2 block">
        Visite dermatologiche a Pescara, Ortona, Sambuceto, Porto San Giorgio, Civitanova Marche e Monsampolo del Tronto
      </h2>
    </Fragment>
  </Hero>

  <!-- Chi Sono Section -->
  <Content
    id="chi-sono"
    isReversed
    tagline="Chi sono"
    title="Il mio Percorso professionale"
    items={[
      {
        title: 'Formazione accademica',
        description:
          "Laureata in Medicina e Chirurgia presso l'Università G. d'Annunzio di Chieti-Pescara, specializzata in Dermatologia e Venereologia con lode.",
      },
      {
        title: 'Specializzazioni',
        description:
          'Particolare interesse per le patologie cutanee infiammatorie e autoimmuni (dermatite atopica, psoriasi, vitiligine), dermochirurgia e dermatologia oncologica.',
      },
      {
        title: 'Esperienza clinica',
        description:
          '2023-2025 Dirigente Medico presso AUSL Romagna e successivamente presso INRCA IRCCS di Fermo-Ancona. Attualmente Specialista ambulatoriale presso AST 4 Fermo.',
      },
    ]}
    image={{
      src: '~/assets/images/dottoressa.jpeg',
      alt: 'Dottoressa Valentina di Gregorio dermatologa a Porto San Giorgio e Civitanova',
    }}
  >
    <Fragment slot="content">
     <p class="text-muted mb-4"> 
Effettuo visite dermatologiche e tricologiche a Pescara, Ortona, Sambuceto, Porto San Giorgio e Civitanova Marche, occupandomi di diagnosi e trattamento delle principali patologie della pelle, dei capelli e delle malattie sessualmente trasmissibili.
 </p>
<p class="text-muted mb-4">
        Ho studiato Medicina e Chirurgia presso l'Università G. d'Annunzio di Chieti-Pescara e successivamente mi sono specializzata in
        Dermatologia e Venereologia presso lo stesso Ateneo con il massimo dei voti.
      </p>
      <p class="text-muted mb-4">
        Durante il mio percorso di specializzazione mi sono occupata in particolare di patologie cutanee infiammatorie e
        autoimmuni come dermatite atopica, psoriasi e vitiligine. Ho inoltre coltivato un particolare interesse per la
        dermochirurgia e la dermatologia oncologica, occupandomi della diagnosi precoce e della prevenzione del melanoma e degli altri tumori cutanei.
      </p>
      <p class="text-muted">
        Dal 2025 sono iscritta presso la scuola S.I.Tri. per approfondire le mie conoscenze nel campo della
        Tricologia.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/5 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Formazione Timeline -->
  <Steps
    id="competenze"
    title="Formazione e Specializzazione"
    tagline=""
    classes={{ headline: { container: '!text-center' } }}
    items={[
      {
        title: '2025 - Scuola S.I.Tri.',
        description:
          'Specializzazione in Tricologia per approfondire la diagnosi e il trattamento delle patologie del cuoio capelluto e dei capelli.',
        icon: 'tabler:school',
      },
      {
        title: '2024 - Master II livello Dermochirurgia',
        description: 'Universita degli Studi di Siena. Formazione avanzata nelle tecniche chirurgiche dermatologiche.',
        icon: 'tabler:certificate',
      },
      {
        title: '2023 - Master II livello Dermatologia Oncologica',
        description:
          'Universita Vanvitelli di Napoli. Approfondimento nella diagnosi e trattamento dei tumori cutanei.',
        icon: 'tabler:certificate',
      },
      {
        title: '2022 - Specializzazione in Dermatologia e Venereologia',
        description:
          "Universita G. d'Annunzio di Chieti-Pescara con votazione 70/70 e lode. Vincitrice 1° premio corso di dermochirurgia avanzata SIDCO Viareggio.",
        icon: 'tabler:award',
      },
    ]}
    image={{
      src: '~/assets/images/percorso.jpg',
      alt: 'Formazione medica',
    }}
  />

  <!-- Patologie Trattate -->
  <Features
    tagline="Aree di Competenza"
    title="Patologie trattate"
    subtitle=""
    items={[
      {
        title: 'Patologie infiammatorie',
        description: 'Acne, Rosacea, Dermatite atopica, Eczema, Psoriasi, Lichen planus, Orticaria',
        icon: 'tabler:flame',
      },
      {
        title: 'Dermatologia oncologica',
        description: 'Melanoma, Cheratosi attinica, Mappatura nei, Epiluminescenza, Prevenzione tumori cutanei utilizzando la videodermatoscopia digitale con modulo AI integrato',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Infezioni cutanee',
        description: 'Micosi, Onicomicosi, Tinea capitis, Pitiriasi versicolor, Mollusco contagioso, Herpes zoster',
        icon: 'tabler:virus',
      },
      {
        title: 'Tricologia',
        description: 'Alopecia Areata, Alopecia Androgenetica, Patologie del cuoio capelluto',
        icon: 'tabler:user',
      },
      {
        title: 'Venereologia',
        description: 'Malattie sessualmente trasmissibili, Verruche genitali, Scabbia',
        icon: 'tabler:heart-plus',
      },
      {
        title: 'Altre patologie',
        description: 'Cisti sebacea, Follicolite, Xerosi, Vitiligine',
        icon: 'tabler:stethoscope',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/5 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <!-- Prestazioni e Prezzi -->
  <Services
    id="prestazioni"
    title="Prestazioni"
    subtitle="Visita dermatologica, tricologia e tutti i servizi dermatologici che offro"
    tagline="Servizi"
    services={[
      { name: 'Prima visita dermatologica', icon: 'tabler:stethoscope' },
      { name: 'Visita dermatologica', icon: 'tabler:report-medical' },
      { name: 'Epiluminescenza', icon: 'tabler:search' },
      { name: 'Mappatura nei', icon: 'tabler:map-pin' },
      { name: 'Prima visita tricologica', icon: 'tabler:user-scan' },
      { name: 'Trattamento verruche e molluschi', icon: 'tabler:first-aid-kit' },
      { name: 'Visita dermatologica + epiluminescenza', icon: 'tabler:clipboard-plus' },
      { name: 'Visita dermatologica + mappatura nei', icon: 'tabler:clipboard-check' },
      { name: 'Visita dermatologica di controllo', icon: 'tabler:refresh' },
      { name: 'Visita tricologica', icon: 'tabler:scan' },
    ]}
    callToAction={{
      text: 'Prenota la tua visita',
      href: miodottoreUrl,
      target: '_blank',
      variant: 'primary',
      icon: 'tabler:calendar',
    }}
  />

  <!-- Recensioni -->
  <Reviews
    id="recensioni"
    title="Cosa dicono i pazienti"
    subtitle="Le recensioni verificate dei miei pazienti a Ortona, Pescara e Porto San Giorgio"
    tagline="Dicono di me"
    reviews={[
      {
        name: 'Anna',
        rating: 5,
