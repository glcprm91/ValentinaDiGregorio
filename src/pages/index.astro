        visitType: 'visita dermatologica',
        verified: true,
      },
      {
        name: 'Marco',
        rating: 5,
        comment: 'La dottoressa è stata gentile e attenta alla mie esigenze.',
        date: '22 febbraio 2026',
        visitType: 'visita tricologia',
        verified: true,
      },
      {
        name: 'Angela',
        rating: 5,
        comment: 'Specialista davvero competente, professionale e preparata ma anche empatica verso il paziente da oggi in poi sarà la mia specialista dermatologa di riferimento.',
        date: '12 febbraio 2026',
        visitType: 'visita dermatologica',
        verified: true,
      },
      {
        name: 'Raffaella',
        rating: 5,
        comment: 'La dottoressa molto competente , mette a suo agio il paziente. Ottima scelta Consiglio',
        date: '10 dicembre 2025',
        visitType: 'mappatura nei',
        verified: true,
      },
    ]}
    callToAction={{
      text: 'Vedi tutte le recensioni su MioDottore',
      href: miodottoreUrl,
      target: '_blank',
      variant: 'secondary',
      icon: 'tabler:external-link',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/5 dark:bg-transparent"></div>
    </Fragment>
  </Reviews>

  <!-- Call to Action -->
  <CallToAction
    id="contatti"
    actions={[
      {
        variant: 'primary',
        text: 'Prenota la tua Visita',
